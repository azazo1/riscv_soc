010000b7 // lui x1, 0x01000, x1 = 0x0100_0000, MMIO 基地址
30248137 // lui x2, 0x30248, 准备 HEX0 到 HEX3 的段码高位
94010113 // addi x2, x2, -1728, x2 = 0x3024_7940, HEX0 到 HEX3 显示 0 到 3
0020a623 // sw x2, 12(x1), 写入 HEX_LOW
000011b7 // lui x3, 0x00001, 准备 HEX4 到 HEX5 的段码高位
21918193 // addi x3, x3, 537, x3 = 0x0000_1219, HEX4 到 HEX5 显示 4 到 5
0030a823 // sw x3, 16(x1), 写入 HEX_HIGH
0040a203 // lw x4, 4(x1), 读取 SW
0040a023 // sw x4, 0(x1), 写入 LEDR
fe000ce3 // beq x0, x0, -8, 回到读取 SW 的循环
